              "model": "confluence:block/rope_side_long",
              "uvlock": true
          },
          "when": {
              "OR": [
                  {
                      "south": "fence"
                  },
                  {
                      "south": "wall"
                  }
              ]
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_side_long",
              "uvlock": true,
              "y": 270
          },
          "when": {
              "OR": [
                  {
                      "east": "fence"
                  },
                  {
                      "east": "wall"
                  }
              ]
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_side_long",
              "uvlock": true,
              "y": 90
          },
          "when": {
              "OR": [
                  {
                      "west": "fence"
                  },
                  {
                      "west": "wall"
                  }
              ]
