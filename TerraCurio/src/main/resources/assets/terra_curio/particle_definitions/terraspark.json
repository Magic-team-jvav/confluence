{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "terra_curio:terraspark",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "terra_curio:generic"
            }
        },
        "components": {
            "minecraft:emitter_local_space": {
                "position": true,
                "rotation": false
            },
            "minecraft:emitter_rate_steady": {
                "spawn_rate": 30,
                "max_particles": 100
            },
            "minecraft:emitter_lifetime_expression": {
                "activation_expression": 1
            },
            "minecraft:emitter_shape_point": {
                "offset": ["variable.particle_random_1*0.2-0.1", 0.01, "variable.particle_random_2*0.2-0.1"]
            },
            "minecraft:particle_initialization": {
                "per_render_expression": "variable.t=variable.particle_age/variable.particle_lifetime;variable.size=0.2-variable.t*0.1;"
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "1.6*variable.emitter_random_1+0.8"
            },
            "minecraft:particle_initial_speed": 0.1,
            "minecraft:particle_motion_dynamic": {
                "linear_acceleration": [0, "variable.particle_age>0.2?-0.8:0.8", 0]
            },
            "minecraft:particle_appearance_billboard": {
                "size": ["variable.size", "variable.size"],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 64,
                    "texture_height": 8,
                    "flipbook": {
                        "base_UV": [56, 0],
                        "size_UV": [8, 8],
                        "step_UV": [-8, 0],
                        "max_frame": 8,
                        "stretch_to_lifetime": true
                    }
                }
            },
            "minecraft:particle_motion_collision": {},
            "minecraft:particle_appearance_lighting": {},
            "minecraft:particle_appearance_tinting": {
                "color": {
                    "interpolant": "variable.t",
                    "gradient": {
                        "0.0": "#147775",
                        "0.75": "#FCFC54"
                    }
                }
            }
        }
    }
}
