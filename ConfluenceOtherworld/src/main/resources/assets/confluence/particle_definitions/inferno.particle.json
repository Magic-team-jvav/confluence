{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:inferno",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "confluence:inferno"
			}
		},
		"curves": {
			"variable.size": {
				"type": "bezier",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [1, 5, 5, 1]
			},
			"variable.color": {
				"type": "bezier",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0, 2, 2, 0]
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 1,
				"max_particles": 400
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 2
			},
			"minecraft:emitter_shape_sphere": {
				"offset": [0, 1, 0],
				"radius": 1,
				"direction": "outwards"
			},
			"minecraft:particle_initialization": {
				"per_render_expression": "variable.size;"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 2
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180, 180)",
				"rotation_rate": "math.random(360, 180)"
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {
				"linear_drag_coefficient": 0.2,
				"rotation_drag_coefficient": 0.3
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.size", "variable.size"],
				"facing_camera_mode": "direction_y",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 0],
					"uv_size": [16, 16]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_drag": 0.2,
				"coefficient_of_restitution": 0.6,
				"collision_radius": 0.2
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "variable.color",
					"gradient": {
						"0.0": "#00000000",
						"0.48": "#00000000",
						"1.0": "#ffffffff"
					}
				}
			}
		}
	}
}