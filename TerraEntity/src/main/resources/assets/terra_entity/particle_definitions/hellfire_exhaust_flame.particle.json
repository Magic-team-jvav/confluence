{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:hellfire_exhaust_flame",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "terra_entity:fire"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 40,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_expression": {},
			"minecraft:emitter_shape_sphere": {
				"radius": 0.3,
				"direction": [10, 0, 0]
			},
			"minecraft:particle_initialization": {
				"per_render_expression": "v.size = 1 - (v.particle_age / v.particle_lifetime);"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.2,0.4)"
			},
			"minecraft:particle_initial_speed": "math.random(-20,-10)",
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.size", "v.size"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 0],
					"uv_size": [16, 16]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FF16FF00",
						"1.0": "#0000FF17"
					}
				}
			}
		}
	}
}