                "material": "particles_alpha",
                "texture": "terra_curio:ball"
            }
        },
        "components": {
            "minecraft:emitter_initialization": {
                "per_update_expression": "variable.r=variable.emitter_age*480;variable.c=math.cos(variable.r);variable.s=math.sin(variable.r);variable.t=1.0/(1.0+variable.s*variable.s);"
