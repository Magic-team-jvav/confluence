{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:rainbow_projectile",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "confluence:rainbow_projectile"
			}
		},
		"curves": {
			"variable.magic_missile": {
				"type": "bezier",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0.2, 0.6, 0, 0.2]
			}
		},
		"events": {
			"event": {
				"particle_effect": {
					"effect": "confluence:rainbow_expiration",
					"type": "particle"
				}
			},
			"event1": {
				"particle_effect": {
					"effect": "confluence:rainbow_expiration_ball",
					"type": "particle"
				}
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": false
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 20,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": 1
			},
			"minecraft:emitter_lifetime_events": {
				"expiration_event": ["event", "event1"]
			},
			"minecraft:emitter_shape_point": {},
			"minecraft:particle_initialization": {
				"per_render_expression": "variable.size = variable.magic_missile;"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.size", "variable.size"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 54,
					"texture_height": 54,
					"uv": [0, 0],
					"uv_size": [54, 54]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
                        "0.0": "#BFFFFFFF",
                        "0.06": "#FFFF0000",
                        "0.2": "#FFFF7F00",
                        "0.36": "#FFFFFF00",
                        "0.5": "#FF00FF00",
                        "0.66": "#FF00FFFF",
                        "0.8": "#FF0000FF",
                        "0.96": "#FF8B00FF",
                        "1.0": "#FFFFFFFF"
					}
				}
			}
		}
	}
}