{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:hellfire",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "terra_entity:fire"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true,
				"velocity": true
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 500
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 0.5,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.3,0.9) * 1.5"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": "math.random(10,18)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 2, 0],
				"linear_drag_coefficient": 4
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(v.particle_age / v.particle_lifetime) + 0.1", "(v.particle_age / v.particle_lifetime) + 0.1"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 0],
					"uv_size": [16, 16]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_drag": 0.4,
				"collision_radius": 0.2
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFDFF00",
						"0.26": "#FF2EC100",
						"0.59": "#FF2F9558",
						"1.0": "#00000000"
					}
				}
			}
		}
	}
}