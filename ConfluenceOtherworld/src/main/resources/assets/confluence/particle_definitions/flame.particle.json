{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:flame",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "minecraft:flame"
			}
		},
		"curves": {
			"variable.size": {
				"type": "bezier",
				"input": "v.particle_age",
