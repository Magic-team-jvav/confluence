{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:flaming_arrow_flame",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "minecraft:flame"
			}
		},
		"curves": {
			"variable.size": {
				"type": "bezier",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0, 0.32, 0, 0]
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": false
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 24,
				"max_particles": 60
			},
			"minecraft:emitter_lifetime_expression": {},
			"minecraft:emitter_shape_point": {
				"offset": ["variable.particle_random_2 * 0.3 - 0.15", "variable.particle_random_3 * 0.3 - 0.15", "variable.particle_random_4 * 0.3 - 0.15"]
			},
			"minecraft:particle_initialization": {
				"per_render_expression": "variable.alpha=1-variable.particle_age/variable.particle_lifetime;variable.size;"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.size", "variable.size"],
				"facing_camera_mode": "rotate_xyz"
			},
			"minecraft:particle_motion_collision": {
				"expire_on_contact": true
			},
			"minecraft:particle_appearance_tinting": {
				"color": [1, 1, 1, "variable.alpha"]
			}
		}
	}
}
