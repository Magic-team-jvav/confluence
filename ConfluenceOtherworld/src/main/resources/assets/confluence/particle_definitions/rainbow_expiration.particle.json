{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:rainbow_expiration",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "confluence:rainbow_expiration"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": false
			},
			"minecraft:emitter_rate_steady": {
