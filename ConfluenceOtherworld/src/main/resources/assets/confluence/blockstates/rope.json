          "when": {
              "north": "wall"
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_knot_wall",
              "uvlock": false
          },
          "when": {
              "south": "wall"
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_knot_wall",
              "uvlock": false,
              "y": 270
          },
          "when": {
              "east": "wall"
