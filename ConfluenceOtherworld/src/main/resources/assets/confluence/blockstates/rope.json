      {
          "apply": {
              "model": "confluence:block/rope_knot_fence",
              "uvlock": false,
              "y": 180
          },
          "when": {
              "north": "fence"
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_knot_fence",
              "uvlock": false
          },
          "when": {
              "south": "fence"
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_knot_fence",
              "uvlock": false,
              "y": 270
          },
          "when": {
              "east": "fence"
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_knot_fence",
