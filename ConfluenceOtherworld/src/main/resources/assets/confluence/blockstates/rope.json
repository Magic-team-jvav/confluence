{
  "multipart": [
    {
      "apply": {
        "model": "confluence:block/rope_str",
        "uvlock": true
      },
      "when": {
        "up": "true",
        "down": "true",
        "north": "none",
        "south": "none",
        "east": "none",
        "west": "none"
      }
    },
    {
      "apply": {
        "model": "confluence:block/rope",
        "uvlock": true
      },
      "when": {
        "OR": [
          {
            "up": "false",
            "down": "false",
            "north": "none",
            "south": "none",
            "east": "none",
            "west": "none"
          },
          {
            "up": "true",
            "down": "false"
          },
          {
            "up": "false",
            "down": "true"
          },
            {
                "north": "rope"
            },
            {
                "south": "rope"
            },
            {
                "east": "rope"
            },
            {
                "west": "rope"
            },
            {
                "north": "fence"
            },
            {
                "south": "fence"
            },
            {
                "east": "fence"
            },
            {
                "west": "fence"
            }
        ]
      }
    },
    {
      "apply": {
        "model": "confluence:block/rope_down",
        "uvlock": true
      },
      "when": {
        "down": "true"
      }
    },
    {
      "apply": {
        "model": "confluence:block/rope_down_false",
