{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "confluence:spore_cloud",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "confluence:spore_cloud"
			}
		},
		"curves": {
			"variable.size": {
				"type": "bezier",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0, 0.4, 0.4, 0]
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": false
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 45,
				"max_particles": 60
			},
			"minecraft:emitter_lifetime_expression": {},
			"minecraft:emitter_shape_sphere": {
				"radius": 1,
				"direction": "outwards"
			},
			"minecraft:particle_initialization": {
				"per_render_expression": "variable.alpha=1-variable.particle_age/variable.particle_lifetime;"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 0.5
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": 1.5,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 1, 0],
				"linear_drag_coefficient": 4
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.size", "variable.size"],
				"facing_camera_mode": "rotate_xyz"
			},
			"minecraft:particle_motion_collision": {
				"collision_drag": 0.4,
				"collision_radius": 0.2
			},
			"minecraft:particle_appearance_tinting": {
				"color": [1, 1, 1, "variable.alpha"]
			}
		}
	}
}