        "up": "false"
      }
    },
      {
          "apply": {
              "model": "confluence:block/rope_side",
              "uvlock": true,
              "y": 180
          },
          "when": {
              "north": "rope"
          }
      },
      {
          "apply": {
              "model": "confluence:block/rope_side",
              "uvlock": true
          },
          "when": {
              "south": "rope"
          }
