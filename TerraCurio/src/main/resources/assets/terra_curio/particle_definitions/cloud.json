{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "terra_curio:cloud",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "terra_curio:big_cloud"
            }
        },
        "components": {
            "minecraft:emitter_local_space": {
                "position": true,
                "rotation": false
            },
            "minecraft:emitter_rate_instant": {
                "num_particles": 10
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 1
            },
            "minecraft:emitter_shape_sphere": {
                "radius": 0.6,
                "direction": "outwards"
            },
            "minecraft:particle_initialization": {
                "per_render_expression": "variable.size=(variable.particle_lifetime-variable.particle_age)/variable.particle_lifetime*0.2+0.2;"
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "variable.particle_random_1+0.4"
            },
            "minecraft:particle_initial_spin": {
                "rotation": "math.random_integer(-180,180)"
            },
            "minecraft:particle_initial_speed": 0.6,
            "minecraft:particle_motion_dynamic": {
                "linear_acceleration": [0, "-variable.particle_random_2-0.3", 0],
                "linear_drag_coefficient": 0.5
            },
            "minecraft:particle_appearance_billboard": {
                "size": ["variable.size", "variable.size"],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 16,
                    "texture_height": 64,
                    "flipbook": {
                        "base_UV": [0, 0],
                        "size_UV": [16, 16],
                        "step_UV": [0, 16],
                        "frames_per_second": 4,
                        "max_frame": 4,
                        "stretch_to_lifetime": true
                    }
                }
            },
            "minecraft:particle_appearance_lighting": {},
            "minecraft:particle_motion_collision": {}
        }
    }
}
